<idea-plugin>
    <id>de.moritzf.openai-usage-quota</id>
    <name>LLM Subscription Usage</name>
    <vendor>Moritzf</vendor>

    <description>
        Tracks LLM subscription usage quotas in the IDE status bar and popup, including OpenAI Codex, Code Review, and OpenCode Go limits.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="openai-usage-quota-with-mcp.xml">com.intellij.mcpServer</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="openai.usage.quota.settings"
                displayName="LLM Subscription Usage"
                parentId="tools"
                instance="de.moritzf.quota.idea.settings.QuotaSettingsConfigurable"/>
        <statusBarWidgetFactory implementation="de.moritzf.quota.idea.ui.toolbar.QuotaStatusBarWidgetFactory" id="openai.usage.quota.widget"/>
    </extensions>

    <actions>
        <action id="openai.usage.quota.mainToolbar"
                class="de.moritzf.quota.idea.ui.toolbar.QuotaMainToolbarAction"
                text="LLM Subscription Usage">
            <add-to-group group-id="MainToolbarRight"/>
        </action>
    </actions>
</idea-plugin>
