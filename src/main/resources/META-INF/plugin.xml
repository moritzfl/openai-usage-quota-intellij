<idea-plugin>
    <id>de.moritzf.openai-usage-quota</id>
    <name>OpenAI Usage Quota</name>
    <vendor>Moritzf</vendor>

    <description>
        Tracks OpenAI Codex and Code Review usage quotas in the IDE status bar and popup, including plan-specific limits across OpenAI subscription tiers, with a browser-based login flow.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="openai-usage-quota-with-mcp.xml">com.intellij.mcpServer</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="openai.usage.quota.settings"
                displayName="OpenAI Usage Quota"
                parentId="tools"
                instance="de.moritzf.quota.idea.QuotaSettingsConfigurable"/>
        <statusBarWidgetFactory implementation="de.moritzf.quota.idea.QuotaStatusBarWidgetFactory" id="openai.usage.quota.widget"/>
    </extensions>
</idea-plugin>
